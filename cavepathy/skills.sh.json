{
  "name": "cavepathy",
  "version": "1.0.0",
  "description": "Terse, accurate coding replies. Merges caveman output compression with Karpathy's LLM-coding guidelines. Zero filler, zero silent assumptions.",
  "author": "cavepathy",
  "license": "MIT",
  "keywords": [
    "caveman",
    "karpathy",
    "compression",
    "coding-style",
    "llm",
    "code-quality"
  ],
  "skill": {
    "path": "skills/cavepathy/SKILL.md",
    "name": "cavepathy"
  },
  "install": {
    "command": "npx skills add cavepathy/cavepathy",
    "targets": {
      "claude-code": {
        "path": "~/.claude/skills/cavepathy/"
      },
      "codex": {
        "path": "~/.codex/skills/cavepathy/"
      },
      "gemini": {
        "path": ".agents/skills/cavepathy/"
      },
      "kilo": {
        "path": ".agents/skills/cavepathy/"
      },
      "openclaw": {
        "path": "~/.openclaw/workspace/skills/cavepathy/"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cavepathy/cavepathy"
  }
}
